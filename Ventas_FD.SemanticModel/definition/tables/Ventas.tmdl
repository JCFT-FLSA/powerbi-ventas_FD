	column OfiVentas = ```
			
			VAR _xOficinaDeVentas = 
			    CALCULATE(
			            VALUES(Sucursales_info[CodSuc]),
			            FILTER(Sucursales_info, Sucursales_info[Oficina de Ventas] = Ventas[Sucursal])
			        )
			       
			VAR _xVendedor = 
			        CALCULATE(
			            VALUES(Vendedores[SucursalVendedor]),
			            FILTER(Vendedores, Vendedores[Codigo] = Ventas[Vendedor])
			        )
			RETURN
			    IF (
			        OR (
			            OR(
			                Ventas[Canal distribución] = 20,
			                Ventas[Canal distribución] = 30),
			            Ventas[Canal distribución] = 11),
			        IF ( 
			            OR(ISBLANK(_xVendedor), _xVendedor = 0),
			            _xOficinaDeVentas,
			            _xVendedor
			        ),// Canal 10 toma la oficina de ventas de la factura
			        _xOficinaDeVentas
			    )
			```
		formatString: 0
		lineageTag: 02ec5c44-96d2-47c0-b880-57864e32600e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IVT_Cartera = ```
			
			    IF(
			        AND(
			            OR(
			            Ventas[Canal distribución] = 11,
			            Ventas[Canal distribución] = 20
			            ),
			            RELATED(Fechas[Año]) >= 2021
			        ),
			        CALCULATE(
			            MAX(CarteraIVT[Vendedor]),
			            FILTER(
			                CarteraIVT,
			                CarteraIVT[Cartera] = Ventas[Cliente] &&
			                CarteraIVT[Periodo]  = RELATED(Fechas[AñoMes]) &&
			                CarteraIVT[Regional] = RELATED(Sucursales[SucursalReg]) && 
			                CarteraIVT[CanalVendedor] = Ventas[Canal distribución]
			            )
			        ),
			        BLANK()
			    )
			```
		lineageTag: 0d324b7d-fde9-4470-89a4-536004a08396
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column nbIVT_Cartera = ```
			
			    CALCULATE(
			        VALUES(Vendedores[NbVendedor]),
			        FILTER(
			            Vendedores,
			            Vendedores[Codigo] = Ventas[IVT_Cartera]
			        )
			    )
			```
		lineageTag: 44c5dfc4-13eb-4e1e-b2fc-2a92ff602c4c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Nit
		dataType: string
		lineageTag: 68a93772-350d-4904-a102-31b970671eea
		summarizeBy: none
		sourceColumn: Nit

		annotation SummarizationSetBy = Automatic

	column QtyContenido = ```
			
			VAR _Contenido = 
			    IF(
			        RELATED(Materiales[Contenido neto]) = 0,
			        1,
			        RELATED(Materiales[Contenido neto])
			    )
			RETURN
			Ventas[Qty] * _Contenido
			```
		lineageTag: b7400d3d-f40a-4bb8-8b5c-f708b5434bb3
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

